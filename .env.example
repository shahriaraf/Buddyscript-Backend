# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=buddyscript
DB_PASS=change_me_in_production
DB_NAME=buddyscript_db

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=generate_a_64_byte_hex_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=generate_a_different_64_byte_hex_secret_here
JWT_REFRESH_EXPIRES=7d

# ── AWS S3 (optional – local storage used if not set) ─────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_KEY=
AWS_S3_BUCKET=buddyscript-media

# ── Rate Limiting ─────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── Feed ──────────────────────────────────────────────────────────
FEED_PAGE_SIZE=20
# Users with more followers than this use pull-based feed (no fanout)
CELEBRITY_THRESHOLD=10000
